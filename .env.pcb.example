# PCB Platform Environment Variables

# PCB Platform Settings
PCB_PLATFORM_ENABLED=true
PCB_DOMAIN=pcb.neogiga.com

# File Upload Limits
PCB_MAX_FILE_SIZE_MB=100
PCB_MAX_GERBER_BUNDLE_MB=100

# Security Settings
PCB_SCAN_FILES=true
PCB_ENCRYPT_FILES=true
PCB_ZIP_BOMB_RATIO=100

# Storage Configuration
PCB_STORAGE_DISK=private
PCB_STORAGE_PATH=pcb-projects

# Project Settings
PCB_PROJECT_CODE_PREFIX=PCB-
PCB_DEFAULT_MARKETPLACE=global

# Queue Names
PCB_QUEUE_FILE_SCAN=pcb-file-scan
PCB_QUEUE_FILE_PROCESS=pcb-file-process
PCB_QUEUE_GERBER_PARSE=pcb-gerber-parse
PCB_QUEUE_GERBER_PREVIEW=pcb-preview
PCB_QUEUE_BOM_IMPORT=pcb-bom-import
PCB_QUEUE_CPL_IMPORT=pcb-cpl-import
PCB_QUEUE_COMPONENT_MATCH=pcb-component-match
PCB_QUEUE_DFM_CHECK=pcb-dfm
PCB_QUEUE_PRICE_CALC=pcb-price
PCB_QUEUE_NOTIFICATION=pcb-notification

# Analysis Settings
PCB_AUTO_ANALYZE_GERBER=true
PCB_PARSER_VERSION=1.0.0
