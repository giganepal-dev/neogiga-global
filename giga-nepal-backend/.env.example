# NeoGiga backend — environment template.
# Copy to .env, then run: php artisan key:generate
# NEVER commit .env. See DEPLOYMENT_NOTES.md for production hardening.

APP_NAME=NeoGiga
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# --- Database -----------------------------------------------------------
# Blueprint mandates PostgreSQL 16+ (Blueprint §10). For quick local dev you
# may use sqlite: set DB_CONNECTION=sqlite and create database/database.sqlite
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=neogiga
DB_USERNAME=neogiga
DB_PASSWORD=

# --- Cache / session / queue --------------------------------------------
# Production: redis for all three (Blueprint §41 cache hierarchy).
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true   # must be true in production (HTTPS only)
SESSION_HTTP_ONLY=true       # prevent JavaScript access to session cookie
SESSION_SAME_SITE=lax        # CSRF protection (lax = safe cross-site navigation)
CACHE_STORE=database
QUEUE_CONNECTION=database
DB_IMPORT_QUEUE=imports
DB_IMPORT_QUEUE_RETRY_AFTER=1860
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# --- Mail ----------------------------------------------------------------
MAIL_MAILER=log
MARKETING_EMAIL_PROVIDER=sandbox
MARKETING_EMAIL_API_BASE_URL=
MARKETING_EMAIL_API_KEY=
MARKETING_EMAIL_ACCOUNT_ID=
MARKETING_EMAIL_WEBHOOK_SECRET=
MARKETING_EMAIL_TIMEOUT=30
MARKETING_EMAIL_TEST_MODE=true
MARKETING_EMAIL_SENDING_ENABLED=false
MARKETING_EMAIL_APPROVAL_REQUIRED=true
MARKETING_EMAIL_TEST_RECIPIENTS=
MARKETING_EMAIL_QUEUE=marketing
MARKETING_PREPARATION_QUEUE=campaign-preparation
MARKETING_EMAIL_RATE_LIMIT_PER_MINUTE=60
MARKETING_EMAIL_DAILY_LIMIT=5000
TRANSACTIONAL_EMAIL_ENABLED=false
TRANSACTIONAL_MAILER=log
TRANSACTIONAL_EMAIL_TEST_MODE=true
TRANSACTIONAL_EMAIL_TEST_RECIPIENT=
TRANSACTIONAL_EMAIL_QUEUE=transactional
TRANSACTIONAL_EMAIL_RETRY_COUNT=3
TRANSACTIONAL_EMAIL_TIMEOUT=30
TRANSACTIONAL_EMAIL_RATE_LIMIT_PER_MINUTE=120
EMAIL_WEBHOOK_SECRET=
EMAIL_WEBHOOK_QUEUE=webhooks
EMAIL_SOFT_BOUNCE_THRESHOLD=3
MAIL_FROM_ADDRESS="hello@neogiga.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- NeoGiga platform -----------------------------------------------------
# Interim admin API gate. Generate with: php -r "echo bin2hex(random_bytes(32));"
# Leave empty to fail closed (all /api/admin/* requests refused).
ADMIN_API_TOKEN=
ADMIN_API_TOKEN_PERMISSIONS=

# Marketplace domain hints (used by seeders/config; resolution is DB-driven).
NEOGIGA_GLOBAL_DOMAIN=neogiga.com
NEOGIGA_INDIA_DOMAIN=neogiga.in
NEOGIGA_NEPAL_DOMAIN=giganepal.com

# ElecForest catalog import (draft/review only by default).
ELECFOREST_PUBLIC_URL=https://neogiga.com
ELECFOREST_IMPORT_QUEUE=catalog-imports
ELECFOREST_IMAGE_QUEUE=catalog-media
ELECFOREST_DERIVATIVE_QUEUE=catalog-media-derivatives
ELECFOREST_IMAGE_DISK=public
ELECFOREST_IMAGE_HOSTS=ueeshop.ly200-cdn.com
ELECFOREST_MAX_IMAGE_BYTES=10485760
ELECFOREST_MAX_IMAGE_DIMENSION=10000
ELECFOREST_MIN_IMAGE_DIMENSION=50
ELECFOREST_IMAGE_TIMEOUT=20
ELECFOREST_IMAGE_CONNECT_TIMEOUT=8
ELECFOREST_IMAGE_REDIRECTS=3
ELECFOREST_LICENSE_NOTE="Supplier catalogue data; redistribution and media rights require administrator review before public use."

# --- Transactional email (registration, orders, status changes) -----------
# Set TRANSACTIONAL_EMAIL_ENABLED=true to send real emails.
# When false, all transactional emails are silently suppressed.
TRANSACTIONAL_EMAIL_ENABLED=false

# When true, all sends are redirected to TRANSACTIONAL_EMAIL_TEST_RECIPIENT
# or logged. Set false in production after smoke-testing.
TRANSACTIONAL_EMAIL_TEST_MODE=true

# Test recipient (used only when TEST_MODE=true). Leave empty to log only.
TRANSACTIONAL_EMAIL_TEST_RECIPIENT=

# Queue for transactional email jobs
TRANSACTIONAL_EMAIL_QUEUE=transactional
TRANSACTIONAL_EMAIL_RETRY_COUNT=3
TRANSACTIONAL_EMAIL_TIMEOUT=30
TRANSACTIONAL_EMAIL_RATE_LIMIT_PER_MINUTE=120

# Primary mailer for transactional: resend, ses, smtp, postmark, log, array
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@neogiga.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- AI (Phase 2+; leave unset — no paid API is called when absent) --------
# ANTHROPIC_API_KEY=
# AI_MODEL=claude-sonnet-5
