+            'from_email' => ['required', 'email', 'max:190'],
+            'reply_to' => ['nullable', 'email', 'max:190'],
+            'domain' => ['required', 'string', 'max:255', 'regex:/^[a-z0-9.-]+$/i'],
+            'base_url' => ['required', 'url:http,https', 'max:2048'],
