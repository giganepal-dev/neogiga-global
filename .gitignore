```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
dist/
build/
target/

# Dependencies
node_modules/
vendor/
*.egg-info/
.pytest_cache/
.mypy_cache/
.coverage
coverage/

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Environment
.env
.env.local
.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Laravel specific
/storage/logs/
/storage/framework/cache/
/storage/framework/sessions/
/storage/framework/views/
/public/hot
/artisan
```