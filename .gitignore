```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/

# Dependencies
vendor/
node_modules/
.env
.env.local
.env.*

# Logs and temp files
*.log
*.tmp

# Editors
.vscode/
.idea/

# Laravel specific
bootstrap/cache/
storage/logs/
storage/framework/
public/storage/

# PHP specific
*.php~
*.swp
```